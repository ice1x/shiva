# Copy to .env and adjust. docker compose picks it up automatically.

# Port the n8n editor UI is exposed on (http://localhost:5678)
N8N_PORT=5678
N8N_HOST=localhost

# Timezone for schedules and logs
GENERIC_TIMEZONE=UTC

# Public base URL for webhook nodes. For real GitHub webhooks, point this
# at a tunnel (ngrok/cloudflared) that forwards to localhost:5678, e.g.:
# WEBHOOK_URL=https://<your-subdomain>.ngrok-free.app/
WEBHOOK_URL=http://localhost:5678/

# Shared secret between n8n and the task-runner sidecar that executes
# Code-node scripts. Any random string works for local use.
N8N_RUNNERS_AUTH_TOKEN=shiva-local-runners-token

# Version tag shared by the n8n and n8n-runners images — they MUST match, so
# pin both here for reproducible runs (e.g. N8N_VERSION=2.28.6). Defaults to
# 'latest' when unset.
# N8N_VERSION=latest

# --- Hosted-LLM API keys (only if a repo reviews with a hosted provider) -----
# The default provider is a free, local, keyless Ollama, so NO key is needed to
# start. Set a key here only when shiva.config.yml routes a repo to a hosted
# provider (llm.provider or llm_by_repo). `scripts/e2e.py setup` reads the key
# from here and imports it into n8n as an encrypted credential — it is never
# committed (.env is gitignored) and never sent to the container as an env var.
#
# Looked up by provider, most specific first:
#   SHIVA_<PROVIDER>_API_KEY   e.g. SHIVA_OPENAI_API_KEY (preferred)
#   SHIVA_LLM_API_KEY          generic fallback (single-provider setups)
# `scripts/e2e.py check` fails until the key for every mapped hosted provider
# is present. Put the raw key as the value — the workflow adds the right header
# (Bearer for most, x-api-key for Anthropic). One line per hosted provider you
# use; the local providers (ollama, lmstudio, vllm) need no key.
#
# SHIVA_OPENAI_API_KEY=sk-...
# SHIVA_DEEPSEEK_API_KEY=...
# SHIVA_QWEN_API_KEY=...
# SHIVA_OPENROUTER_API_KEY=sk-or-...
# SHIVA_ANTHROPIC_API_KEY=sk-ant-...
# SHIVA_LLM_API_KEY=...
